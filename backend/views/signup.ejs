<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — NexusApp</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #080c14;
      --surface: #0f1623;
      --surface-2: #161e2e;
      --border: rgba(99, 160, 255, 0.12);
      --accent: #4f8ef7;
      --accent-dim: rgba(79, 142, 247, 0.15);
      --accent-glow: rgba(79, 142, 247, 0.35);
      --text: #e8edf5;
      --text-muted: #6b7a99;
      --text-dim: #3d4d6a;
      --success: #10d078;
      --error: #f04a5a;
      --error-bg: rgba(240, 74, 90, 0.1);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(79, 142, 247, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(79, 142, 247, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    body::after {
      content: '';
      position: fixed;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(ellipse, rgba(79, 142, 247, 0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .auth-wrapper {
      width: 100%;
      max-width: 440px;
      padding: 24px;
      position: relative;
      z-index: 1;
      animation: fadeUp 0.5s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo { text-align: center; margin-bottom: 40px; }
    .logo-mark { display: inline-flex; align-items: center; gap: 10px; }
    .logo-icon {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--accent), #7c5fe6);
      border-radius: 8px; display: flex; align-items: center; justify-content: center;
    }
    .logo-icon svg { width: 20px; height: 20px; }
    .logo-text {
      font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800;
      letter-spacing: -0.5px; color: var(--text);
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 40px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255,255,255,0.02);
    }

    .card-header { margin-bottom: 32px; }
    .card-title {
      font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 700;
      letter-spacing: -0.5px; color: var(--text); margin-bottom: 6px;
    }
    .card-subtitle { font-size: 14px; color: var(--text-muted); font-weight: 300; }

    .flash-container { margin-bottom: 20px; }
    .flash {
      padding: 12px 16px; border-radius: 8px; font-size: 13.5px;
      display: flex; align-items: flex-start; gap: 8px; margin-bottom: 8px;
    }
    .flash-error {
      background: var(--error-bg);
      border: 1px solid rgba(240, 74, 90, 0.25); color: #f88;
    }
    .flash-success {
      background: rgba(16, 208, 120, 0.1);
      border: 1px solid rgba(16, 208, 120, 0.25); color: #5ef5b0;
    }
    .flash-icon { font-size: 15px; flex-shrink: 0; margin-top: 1px; }

    .form-group { margin-bottom: 20px; }
    label {
      display: block; font-size: 12px; font-weight: 500;
      letter-spacing: 0.8px; text-transform: uppercase;
      color: var(--text-muted); margin-bottom: 8px;
    }
    input {
      width: 100%; padding: 13px 16px;
      background: var(--surface-2); border: 1px solid var(--border);
      border-radius: 8px; color: var(--text);
      font-family: 'DM Sans', sans-serif; font-size: 15px;
      outline: none; transition: border-color 0.2s, box-shadow 0.2s;
    }
    input::placeholder { color: var(--text-dim); }
    input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }

    .password-hint {
      font-size: 12px; color: var(--text-dim);
      margin-top: 6px; padding-left: 2px;
    }

    .btn-primary {
      width: 100%; padding: 14px 24px;
      background: var(--accent); border: none; border-radius: 8px;
      color: #fff; font-family: 'Syne', sans-serif;
      font-size: 15px; font-weight: 600; cursor: pointer;
      transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
      margin-top: 8px; letter-spacing: 0.2px;
    }
    .btn-primary:hover {
      background: #6da8ff;
      box-shadow: 0 4px 20px var(--accent-glow);
      transform: translateY(-1px);
    }
    .btn-primary:active { transform: translateY(0); }

    .auth-link {
      text-align: center; margin-top: 24px;
      font-size: 14px; color: var(--text-muted);
    }
    .auth-link a { color: var(--accent); text-decoration: none; font-weight: 500; }
    .auth-link a:hover { text-decoration: underline; }

    .divider { border: none; border-top: 1px solid var(--border); margin: 28px 0; }

    .terms {
      font-size: 12px; color: var(--text-dim);
      text-align: center; margin-top: 16px; line-height: 1.6;
    }
  </style>
</head>
<body>
  <div class="auth-wrapper">
    <div class="logo">
      <div class="logo-mark">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>
        <span class="logo-text">Nexus</span>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h1 class="card-title">Create account</h1>
        <p class="card-subtitle">Join Nexus and start managing your work</p>
      </div>

      <% if (errors && errors.length > 0) { %>
        <div class="flash-container">
          <% if (Array.isArray(errors)) { %>
            <% errors.forEach(err => { %>
              <div class="flash flash-error">
                <span class="flash-icon">⚠</span><span><%= err %></span>
              </div>
            <% }); %>
          <% } else { %>
            <div class="flash flash-error">
              <span class="flash-icon">⚠</span><span><%= errors %></span>
            </div>
          <% } %>
        </div>
      <% } %>

      <form action="/signup" method="POST" novalidate>
        <div class="form-group">
          <label for="name">Full Name</label>
          <input
            type="text"
            id="name"
            name="name"
            value="<%= formData.name || '' %>"
            placeholder="Jane Doe"
            required
            autocomplete="name"
          />
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            value="<%= formData.email || '' %>"
            placeholder="you@example.com"
            required
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="At least 6 characters"
            required
            autocomplete="new-password"
          />
          <p class="password-hint">Minimum 6 characters</p>
        </div>

        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            placeholder="Repeat your password"
            required
            autocomplete="new-password"
          />
        </div>

        <button type="submit" class="btn-primary">Create Account →</button>
      </form>

      <p class="terms">By creating an account, you agree to our Terms of Service and Privacy Policy.</p>

      <hr class="divider" />

      <p class="auth-link">
        Already have an account? <a href="/login">Sign in</a>
      </p>
    </div>
  </div>
</body>
</html>
